# ====================================================
# INCUBANT MONITOR - Environment Configuration Example
# ====================================================

# Port for the Express server (Defaults to 3001)
PORT=3001

# Node Environment (development | production)
NODE_ENV=development

# Session secret for cookie signing (min 32 characters recommended)
SESSION_SECRET=your-random-session-secret-here

# Main Database URL (Postgres)
# Using direct connection for Prisma push/generate
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# Direct connection to the database (Required for Prisma if using connection pooling)
DIRECT_URL="postgresql://user:password@host:port/dbname?schema=public"

# Supabase Keys (Real-Time Storage & Events)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Gemini API Key (For AI-powered analysis)
GEMINI_API_KEY="AIza..."

# Deployment: Domain of the frontend in production (Vercel)
# Used for CORS configuration
FRONTEND_DOMAIN="https://incubantmonitor.vercel.app"

# (Optional) Google Drive IDs for evidence storage fallback
DRIVE_FOLDER_PHOTOS_ID=""
DRIVE_FOLDER_REPORTS_ID=""
DRIVE_FOLDER_CLOSING_REPORTS_ID=""
