generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String               @id @default(uuid())
  nombre          String
  pin_acceso      String               @unique
  rol             Role                 @default(OPERARIO)
  turno           String               @default("Turno 1")
  estado          String               @default("Activo")
  ultimo_acceso   DateTime?
  session_expires DateTime?
  breaks          Break[]
  logs            HourlyLog[]
  incidents       Incident[]
  reports         Report[]
  assignments     ScheduleAssignment[]
  sessions        Session[]
  leaveRequests   LeaveRequest[]       @relation("RequesterRelation")
  reviewedRequests LeaveRequest[]      @relation("ReviewerRelation")
}

model LeaveRequest {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tipo            String    // PERMISO, VACACIONES, AUSENCIA, OTRO
  fecha_inicio    DateTime
  fecha_fin       DateTime
  motivo          String
  observaciones   String?
  estado          String    @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  respuesta       String?   // Respuesta del supervisor
  requester_id    String
  reviewer_id     String?
  requester       User      @relation("RequesterRelation", fields: [requester_id], references: [id], onDelete: Cascade)
  reviewer        User?     @relation("ReviewerRelation", fields: [reviewer_id], references: [id], onDelete: SetNull)
}

model Machine {
  id             String      @id @default(uuid())
  tipo           MachineType
  numero_maquina Int
  logs           HourlyLog[]
  incidents      Incident[]
  reports        Report[]

  @@unique([tipo, numero_maquina])
}

model Report {
  id                String   @id @default(uuid())
  fecha_hora        DateTime @default(now())
  imageUrl          String?
  pdfUrl            String?
  tempPrincipalReal Float?   @default(0)
  tempPrincipalSP   Float?   @default(0)
  tempAireReal      Float?   @default(0)
  tempAireSP        Float?   @default(0)
  humidityReal      Float?   @default(0)
  humiditySP        Float?   @default(0)
  co2Real           Float?   @default(0)
  co2SP             Float?   @default(0)
  isAlarm           Boolean? @default(false)
  isClosingReport   Boolean? @default(false)
  processStatus     String?  @default("NORMAL")
  observaciones     String?  @default("")
  temperature       Float?   @default(0)
  humidity          Float?   @default(0)
  user_id           String
  machine_id        String
  machine           Machine  @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Break {
  id         String   @id @default(uuid())
  fecha_hora DateTime @default(now())
  tipo       String
  duracion   Int?
  estado     String   @default("EN_CURSO")
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Shift {
  id          String               @id @default(uuid())
  nombre      String               @unique
  hora_inicio String
  hora_fin    String
  color       String?              @default("#f5a623")
  assignments ScheduleAssignment[]
}

model ScheduleAssignment {
  id       String   @id @default(uuid())
  user_id  String
  shift_id String
  fecha    DateTime
  shift    Shift    @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, fecha])
}

model HourlyLog {
  id                       String   @id @default(uuid())
  fecha_hora               DateTime @default(now())
  user_id                  String
  machine_id               String
  photo_url                String?
  temp_principal_actual    Float
  temp_principal_consigna  Float
  co2_actual               Float
  co2_consigna             Float
  fan_speed                Float
  temp_secundaria_actual   Float
  temp_secundaria_consigna Float
  is_na                    Boolean  @default(false)
  temp_superior_actual     Float?
  observaciones            String?
  machine                  Machine  @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Incident {
  id          String   @id @default(uuid())
  fecha_hora  DateTime @default(now())
  user_id     String
  machine_id  String?
  titulo      String
  descripcion String
  tipo        String
  machine     Machine? @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  user_id   String
  expiresAt DateTime
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

enum Role {
  OPERARIO
  SUPERVISOR
  JEFE
}

enum MachineType {
  INCUBADORA
  NACEDORA
}
